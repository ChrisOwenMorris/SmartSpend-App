<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Base.Theme.SmartSpend" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ss_blue</item>
        <item name="colorPrimaryVariant">@color/ss_blue_dark</item>
        <item name="colorSecondary">@color/ss_green</item>
        <item name="android:windowBackground">@color/ss_background</item>
    </style>

    <style name="Theme.SmartSpend" parent="Base.Theme.SmartSpend" />

    <!-- Custom style for the input fields -->
    <style name="SmartSpend.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/ss_blue</item>
        <item name="hintTextColor">@color/ss_text_secondary</item>
    </style>

    <!-- Custom style for primary button -->
    <style name="SmartSpend.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/ss_blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>