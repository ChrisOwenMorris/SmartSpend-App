<?xml version="1.0" encoding="utf-8"?>
<!--
    Dashboard layout — Member 1 (Christopher Morris)
    Matches the POE Part 1 Figma design exactly:

    SCROLL SECTION 1 — Balance header + Expenses/Budget cards + Budget Overview progress bar
    SCROLL SECTION 2 — Spending by Category doughnut chart
    SCROLL SECTION 3 — Monthly Trend bar chart
    SCROLL SECTION 4 — Monthly Comparison (Income vs Expenses bar)

    Wrapped in DrawerLayout for hamburger navigation.
-->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ===== MAIN CONTENT ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F5F7FA">

        <!-- ── TOP TOOLBAR ── -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/gradient_header"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="16dp"
            android:elevation="6dp">

            <!-- Hamburger icon -->
            <ImageButton
                android:id="@+id/ibHamburger"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:contentDescription="Open menu"
                app:tint="@color/white" />

            <!-- Screen title -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/app_name"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ── SCROLLABLE DASHBOARD BODY ── -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ══════════════════════════════════════════
                     SECTION 1: Total Balance + Budget Overview
                     (POE page 29 — top card)
                     ══════════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gradient_header"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="28dp">

                    <!-- "Total Balance" label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Balance"
                        android:textColor="#CCE0FF"
                        android:textSize="14sp" />

                    <!-- Big balance amount -->
                    <TextView
                        android:id="@+id/tvTotalBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R4,820.75"
                        android:textColor="@color/white"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <!-- "from last month" subtitle -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="from last month"
                        android:textColor="#CCE0FF"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="16dp" />

                    <!-- Expenses + Budget side-by-side mini cards -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Expenses card -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/card_background"
                            android:elevation="4dp"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <!-- Red arrow icon + "Expenses" label row -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:text="↘"
                                    android:textColor="#E53935"
                                    android:textSize="16sp"
                                    android:gravity="center"
                                    android:background="#FFF3F3"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text="Expenses"
                                    android:textColor="@color/ss_text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <!-- Expenses amount -->
                            <TextView
                                android:id="@+id/tvExpensesAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="R3,220"
                                android:textColor="@color/ss_text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Budget card -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/card_background"
                            android:elevation="4dp"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <!-- Blue budget icon + "Budget" label row -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:text="💳"
                                    android:textSize="14sp"
                                    android:gravity="center"
                                    android:background="#EBF5FF" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text="Budget"
                                    android:textColor="@color/ss_text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <!-- Budget amount -->
                            <TextView
                                android:id="@+id/tvBudgetAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="R4,500"
                                android:textColor="@color/ss_text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── BUDGET OVERVIEW CARD (inside white area, overlaps gradient) ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="-12dp"
                    android:background="@drawable/card_background"
                    android:elevation="8dp"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- "Budget Overview" heading -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Budget Overview"
                        android:textColor="@color/ss_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- "Used this month" + percentage row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Used this month"
                            android:textColor="@color/ss_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvBudgetPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="72%"
                            android:textColor="@color/ss_blue"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Progress bar (blue fill) -->
                    <ProgressBar
                        android:id="@+id/progressBudget"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="72"
                        android:progressTint="@color/ss_blue"
                        android:progressBackgroundTint="#E0E0E0" />

                    <!-- Remaining + Total Budget row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <!-- Remaining -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Remaining"
                                android:textColor="@color/ss_text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvBudgetRemaining"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R1,280"
                                android:textColor="@color/ss_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Total Budget -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Budget"
                                android:textColor="@color/ss_text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvBudgetTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R4,500"
                                android:textColor="@color/ss_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ══════════════════════════════════════════
                     SECTION 2: Spending by Category — Doughnut chart
                     (POE page 29 — second card / scroll down)
                     ══════════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/card_background"
                    android:elevation="4dp"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Section heading -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spending by Category"
                        android:textColor="@color/ss_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Custom doughnut chart view -->
                    <com.smartspend.views.DonutChartView
                        android:id="@+id/donutChart"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="8dp" />

                    <!-- Legend row 1: Food + Transport -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <!-- Food legend dot -->
                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/legend_dot_green" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Food"
                            android:textColor="@color/ss_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvFoodAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R850"
                            android:textColor="@color/ss_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Transport legend row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/legend_dot_blue" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Transport"
                            android:textColor="@color/ss_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvTransportAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R420"
                            android:textColor="@color/ss_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Housing legend row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/legend_dot_purple" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Housing"
                            android:textColor="@color/ss_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvHousingAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R1,200"
                            android:textColor="@color/ss_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Entertainment legend row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/legend_dot_teal" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Entertainment"
                            android:textColor="@color/ss_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvEntertainmentAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R750"
                            android:textColor="@color/ss_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>

                <!-- ══════════════════════════════════════════
                     SECTION 3: Monthly Trend — Bar chart
                     (POE page 30 — third card)
                     ══════════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/card_background"
                    android:elevation="4dp"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Total Spending label + amount -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Spending"
                            android:textColor="@color/ss_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvTotalSpending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R3,220"
                            android:textColor="@color/ss_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- "Spending Trends" heading -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Spending Trends"
                        android:textColor="@color/ss_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Custom bar / line chart view -->
                    <com.smartspend.views.TrendChartView
                        android:id="@+id/trendChart"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="10dp" />

                    <!-- Average Monthly Spending row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Average Monthly Spending"
                            android:textColor="@color/ss_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvAvgSpending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R3,134"
                            android:textColor="@color/ss_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>

                <!-- ══════════════════════════════════════════
                     SECTION 4: Monthly Comparison bar chart
                     (POE page 33 — Income vs Expenses)
                     ══════════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/card_background"
                    android:elevation="4dp"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- "Monthly Comparison" heading -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly Comparison"
                        android:textColor="@color/ss_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Custom comparison bar chart -->
                    <com.smartspend.views.ComparisonChartView
                        android:id="@+id/comparisonChart"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:layout_marginTop="10dp" />

                    <!-- Income legend dot -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/legend_dot_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp"
                            android:text="Income"
                            android:textColor="@color/ss_text_secondary"
                            android:textSize="13sp" />

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/legend_dot_blue" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Expenses"
                            android:textColor="@color/ss_text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Total Income + Total Expenses summary -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <!-- Total Income box -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/legend_box_green"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Income"
                                android:textColor="@color/ss_text_secondary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvTotalIncome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="R10,400"
                                android:textColor="@color/ss_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Total Expenses box -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/legend_box_blue"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Expenses"
                                android:textColor="@color/ss_text_secondary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvTotalExpenses"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="R6,170"
                                android:textColor="@color/ss_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- ===== NAVIGATION DRAWER ===== -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_menu" />

</androidx.drawerlayout.widget.DrawerLayout>