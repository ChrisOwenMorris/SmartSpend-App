<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6F8">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/gradient_header"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/btnMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☰"
            android:textSize="24sp"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reports"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- BODY -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- FILTERS: PERIOD + MONTH + CATEGORY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:text="@string/filter_reports"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    style="?android:attr/buttonBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <Button
                        style="?android:attr/buttonBarButtonStyle"
                        android:id="@+id/btnWeek"
                        android:text="@string/week"
                        android:textColor="#FFFFFF"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_gradient_background"
                        app:backgroundTint="@null" />

                    <Button
                        style="?android:attr/buttonBarButtonStyle"
                        android:id="@+id/btnMonth"
                        android:text="@string/month"
                        android:textColor="#FFFFFF"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_gradient_background"
                        app:backgroundTint="@null" />

                    <Button
                        style="?android:attr/buttonBarButtonStyle"
                        android:id="@+id/btnYear"
                        android:text="@string/year"
                        android:textColor="#FFFFFF"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_gradient_background"
                        app:backgroundTint="@null" />
                </LinearLayout>

                <!-- MONTH & CATEGORY FILTERS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etMonthPicker"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="@string/_2024_01"
                        android:background="@drawable/card_background"
                        android:gravity="center"
                        android:inputType="none"
                        android:drawableEnd="@android:drawable/ic_menu_my_calendar"
                        android:drawablePadding="8dp"
                        android:padding="12dp" />

                    <Spinner
                        android:id="@+id/spCategoryFilter"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/card_background"
                        android:padding="12dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- SUMMARY CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_gradient_background"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvPeriodLabel"
                    android:text="@string/all_categories_month_2024_01"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvTotalAmount"
                    android:text="R 0.00"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvComparison"
                    android:text="@string/net_r_0_00"
                    android:textColor="#DFFFE2"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- INCOME VS EXPENSES CHART -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:text="Income vs Expenses"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="8dp"/>

                <com.smartspend.IncomeExpenseBarChartView
                    android:id="@+id/incomeExpenseChart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp" />
            </LinearLayout>

            <!-- PIE CHART -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:layout_marginBottom="12dp"
                android:padding="16dp">

                <TextView
                    android:text="Spending by Category"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="16dp"/>

                <com.smartspend.PieChartView
                    android:id="@+id/pieChart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_gravity="center" />

                <TextView
                    android:id="@+id/tvPieChartPlaceholder"
                    android:text="@string/no_data_available"
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- TREND CHART -->
            <LinearLayout
                android:id="@+id/layoutLineGraph"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:text="6 Month Trends"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#111111"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <com.smartspend.TrendChartView
                    android:id="@+id/trendChart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp" />
            </LinearLayout>

            <!-- TOP CATEGORIES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/top_categories"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_marginBottom="14dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTopMerchants"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>

            <!-- MONTHLY ENTRIES LIST -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/monthly_entries"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_marginBottom="14dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvMonthlyEntries"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>

            <!-- EXPORT BUTTON -->
            <Button
                android:id="@+id/btnExport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/export_report"
                android:textColor="#FFFFFF"
                android:background="@drawable/card_gradient_background"
                android:padding="14dp"
                app:backgroundTint="@null"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>