<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6F8">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/gradient_header"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/btnMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text"
            android:textSize="24sp"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_reports"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- BODY -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- REPORT PERIOD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:text="@string/label_reporting_period"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    style="?android:attr/buttonBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <Button
                        style="?android:attr/buttonBarButtonStyle"
                        android:id="@+id/btnWeek"
                        android:text="@string/btn_week"
                        android:textColor="#FFFFFF"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_gradient_background"
                        app:backgroundTint="@null" />

                    <Button
                        style="?android:attr/buttonBarButtonStyle"
                        android:id="@+id/btnMonth"
                        android:text="@string/btn_month"
                        android:textColor="#FFFFFF"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_gradient_background"
                        app:backgroundTint="@null" />

                    <Button
                        style="?android:attr/buttonBarButtonStyle"
                        android:id="@+id/btnYear"
                        android:text="@string/btn_year"
                        android:textColor="#FFFFFF"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_gradient_background"
                        app:backgroundTint="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- SUMMARY CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_gradient_background"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvPeriodLabel"
                    android:text="@string/net_income_march_2026"
                    android:textColor="#FFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvTotalAmount"
                    android:text="@string/r_4_570_20"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvComparison"
                    android:text="@string/_18_from_february"
                    android:textColor="#DFFFE2"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- CHART PLACEHOLDER -->
            <LinearLayout
                android:id="@+id/layoutBarChart"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/card_background"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:text="@string/income_vs_expenses"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvBarChartPlaceholder"
                    android:text="@string/bar_chart_placeholder"
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- PIE CHART -->
            <LinearLayout
                android:id="@+id/layoutPieChart"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/card_background"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:text="@string/spending_by_category"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvPieChartPlaceholder"
                    android:text="@string/pie_chart_placeholder"
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- LINE GRAPH -->
            <LinearLayout
                android:id="@+id/layoutLineGraph"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/card_background"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:text="@string/_6_month_trends"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvLineGraphPlaceholder"
                    android:text="@string/line_graph_placeholder"
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- TOP MERCHANTS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/top_merchants"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_marginBottom="14dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTopMerchants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>

            <!-- EXPORT BUTTON -->
            <Button
                android:id="@+id/btnExport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/export_report_pdf"
                android:textColor="#FFFFFF"
                android:background="@drawable/card_gradient_background"
                android:padding="14dp"
                app:backgroundTint="@null"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>