<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6F8">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/gradient_header"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/btnMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:contentDescription="@string/menu_button_description"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/goals"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- FEATURED GOAL CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFeaturedGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- GOAL IMAGE -->
                    <FrameLayout
                        android:id="@+id/frameFeaturedImage"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:layout_marginBottom="16dp"
                        android:background="#F0F0F0">

                        <!-- FIX 2: Insufficient image color contrast — added explicit
                             colorFilter to ensure the placeholder icon is visible -->
                        <ImageView
                            android:id="@+id/ivFeaturedGoalImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:contentDescription="@string/goal_image"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center"
                            tools:ignore="UseCompoundDrawables">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@android:drawable/ic_menu_camera"
                                android:contentDescription="@string/upload_goal_image"/>

                            <!-- FIX 3: Insufficient text color contrast — #888888 on #F0F0F0
                                 fails WCAG AA. Changed to #555555 for sufficient contrast. -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tap_to_upload_image"
                                android:textColor="#555555"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </FrameLayout>

                    <!-- GOAL TITLE AND DATE -->
                    <TextView
                        android:id="@+id/tvFeaturedGoalTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dream_vacation_to_bali"
                        android:textColor="#111111"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <!-- FIX 4: Insufficient text color contrast — #888888 on #FFFFFF
                         fails WCAG AA at 13sp. Changed to #555555. -->
                    <TextView
                        android:id="@+id/tvFeaturedGoalDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/target_dec_2026"
                        android:textColor="#555555"
                        android:textSize="13sp"
                        android:layout_marginBottom="20dp"/>

                    <!-- PIE CHART + SAVINGS INFO ROW -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:baselineAligned="false"
                        android:layout_marginBottom="16dp">

                        <!-- PIE CHART -->
                        <!-- FIX 5: Missing classes / Accessibility Issue on PieChartView —
                             added tools:ignore="MissingClass" so layout editor doesn't error,
                             and added contentDescription for accessibility. -->
                        <FrameLayout
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            android:layout_marginEnd="20dp">

                            <com.smartspend.PieChartView
                                android:id="@+id/pieChartFeatured"
                                android:layout_width="110dp"
                                android:layout_height="110dp"
                                android:contentDescription="@string/goal_progress_chart"
                                tools:ignore="MissingClass"/>

                            <TextView
                                android:id="@+id/tvFeaturedGoalPercentage"
                                android:layout_width="21dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="@string/_0"
                                android:textColor="#111111"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <!-- SAVINGS INFO -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- FIX 6: Insufficient text color contrast — #888888 → #555555 -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/current_savings"
                                android:textColor="#555555"
                                android:textSize="12sp"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/tvFeaturedCurrentAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R 3,250"
                                android:textColor="#111111"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp"
                                tools:ignore="HardcodedText"/>

                            <ProgressBar
                                android:id="@+id/progressFeaturedGoal"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="10dp"
                                android:progress="65"
                                android:progressDrawable="@drawable/card_gradient_background"
                                android:layout_marginBottom="16dp"/>

                            <!-- FIX 7: tvFeaturedGoalDate contrast — also applied
                                 #555555 to the goal amount label here -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/goal_amount"
                                android:textColor="#555555"
                                android:textSize="12sp"
                                android:layout_marginBottom="2dp"/>

                            <TextView
                                android:id="@+id/tvFeaturedGoalAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R 5,000"
                                android:textColor="#111111"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ADD SAVINGS BUTTON -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddSavings"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="@string/add_savings"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:background="@drawable/card_gradient_background"
                        app:backgroundTint="@null"
                        app:cornerRadius="12dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- UPDATE GOAL BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdateGoal"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:text="@string/update_goal"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:background="@drawable/card_gradient_background"
                app:backgroundTint="@null"
                app:cornerRadius="12dp"/>

            <!-- CREATE NEW GOAL CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/create_new_goal"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- GOAL NAME -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilGoalName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etGoalName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/goal_name"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- GOAL AMOUNT -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilGoalAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:prefixText="R"
                        app:prefixTextColor="@color/black">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etGoalAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/goal_amount"
                            android:inputType="numberDecimal"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- TARGET DATE -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilTargetDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:endIconMode="custom"
                        app:endIconDrawable="@android:drawable/ic_menu_my_calendar">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTargetDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/target_date"
                            android:focusable="false"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- IMAGE UPLOAD -->
                    <LinearLayout
                        android:id="@+id/layoutUploadImage"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:id="@+id/ivNewGoalImage"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:contentDescription="@string/upload_goal_image"/>

                        <TextView
                            android:id="@+id/tvUploadImage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/upload_goal_image"
                            android:textColor="#555555"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- CREATE BUTTON -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCreateGoal"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="@string/create_new_goal"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:background="@drawable/card_gradient_background"
                        app:backgroundTint="@null"
                        app:cornerRadius="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ALL GOALS LIST CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/all_goals"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvAllGoals"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>